<Window
    x:Class="JasperMediaPlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvs="using:LibVLCSharp.Platforms.Windows"
    Title="Jasper Media Player">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0,150,0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Glyph="&#xE714;" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1"
                       Text="Jasper Media Player"
                       VerticalAlignment="Center"
                       FontSize="15"
                       FontWeight="SemiBold" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="OpenFileButton" Click="OpenFileButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="Open File" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="14,0,14,10" CornerRadius="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <lvs:VideoView x:Name="VideoView" />
            <MediaPlayerElement x:Name="NativeStreamView"
                                AreTransportControlsEnabled="False"
                                Stretch="Uniform"
                                Visibility="Collapsed" />

            <Border x:Name="EmptyState"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="14"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8B2;" FontSize="42" />
                    <TextBlock Text="Open a video or paste a stream URL"
                               FontSize="20"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Real VLC engine. Native Windows 11 UI. Very tasty combo."
                               Opacity="0.75"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Padding="14,0,14,14">
            <Border CornerRadius="14" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UrlBox" PlaceholderText="Paste a stream URL here" />
                        <Button Grid.Column="1" x:Name="PlayUrlButton" Click="PlayUrlButton_Click" Content="Play URL" />
                    </Grid>

                    <TextBlock x:Name="StatusText"
                               Text="Ready. Paste a direct stream URL, then press Play URL."
                               FontSize="12"
                               Opacity="0.72" />

                    <Slider x:Name="SeekSlider"
                            Minimum="0"
                            Maximum="1000"
                            ValueChanged="SeekSlider_ValueChanged"
                            PointerPressed="SeekSlider_PointerPressed"
                            PointerReleased="SeekSlider_PointerReleased" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="14" />
                                <TextBlock x:Name="PlayPauseText" Text="Play" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" x:Name="StopButton" Click="StopButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE71A;" FontSize="14" />
                                <TextBlock Text="Stop" />
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Column="2"
                                   x:Name="TimeText"
                                   Text="00:00 / 00:00"
                                   VerticalAlignment="Center"
                                   Opacity="0.8" />

                        <FontIcon Grid.Column="3" Glyph="&#xE767;" FontSize="16" VerticalAlignment="Center" />
                        <Slider Grid.Column="4"
                                x:Name="VolumeSlider"
                                Minimum="0"
                                Maximum="100"
                                Value="85"
                                ValueChanged="VolumeSlider_ValueChanged" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
